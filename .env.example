# Supabase — get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The public site URL (used for share links and Open Graph metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Donation button target (Bit / PayBox / etc). Leave empty to hide the donation CTA.
NEXT_PUBLIC_DONATION_URL=
